{
  "emoji": "🪞",
  "requires": {
    "bins": ["zora", "node"],
    "env": ["ZORA_PRIVATE_KEY"]
  },
  "cron": "* * * * *",
  "autostart": false,
  "automaton": {
    "managed": true,
    "entrypoint": "scripts/run.mjs"
  },
  "tunables": [
    {
      "env": "ZORA_COPYTRADE_LIVE",
      "type": "boolean",
      "default": false,
      "label": "Enable live copy trading"
    },
    {
      "env": "ZORA_COPYTRADE_SOURCE_ADDRESSES",
      "type": "string",
      "default": "",
      "label": "Manual source wallets"
    },
    {
      "env": "ZORA_COPYTRADE_IMPORT_LEADERBOARD",
      "type": "boolean",
      "default": false,
      "label": "Import leaderboard traders"
    },
    {
      "env": "ZORA_COPYTRADE_SPEND_TOKEN",
      "type": "string",
      "default": "eth",
      "label": "Spend token"
    },
    {
      "env": "ZORA_COPYTRADE_EXIT_TOKEN",
      "type": "string",
      "default": "eth",
      "label": "Exit token"
    },
    {
      "env": "ZORA_COPYTRADE_MAX_BUY_USD",
      "type": "number",
      "default": 25,
      "range": [1, 5000],
      "step": 1,
      "label": "Max USD per copied buy"
    },
    {
      "env": "ZORA_COPYTRADE_DAILY_CAP_USD",
      "type": "number",
      "default": 100,
      "range": [10, 10000],
      "step": 10,
      "label": "Daily USD spend cap"
    },
    {
      "env": "ZORA_COPYTRADE_MAX_POSITIONS",
      "type": "number",
      "default": 5,
      "range": [1, 20],
      "step": 1,
      "label": "Max copied positions"
    }
  ]
}
